# Copy this file to .env and fill in values before building for distribution.
# CRITICAL: Change NOVA_DEV_SECRET before packaging! This is the secret used to:
#   1. Generate activation keys for your clients
#   2. Compute the rotating developer maintenance password
# If you leave it as the default, ANYONE with the source can generate valid keys.

NOVA_DEV_SECRET=replace-with-a-long-random-secret-string-min-32-chars
